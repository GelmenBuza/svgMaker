generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String?
  role      String
  password  String
  refresh_token String?
  createdAt DateTime @default(now())
}

model Messages {
  id         Int      @id @default(autoincrement())
  room       String   @default("public")
  sender_id  Int
  nickname   String?
  content    String
  createdAt  DateTime @default(now())
}
